#include <stdio.h>

struct Item {
    char name[30];
    int quantity;
    float price;
};

int main() {
    int n, i;
    float total = 0, discount = 0, finalAmount;

    printf("Enter number of items purchased: ");
    scanf("%d", &n);

    struct Item items[n];

    for(i = 0; i < n; i++) {
        printf("\nEnter name of item %d: ", i+1);
        scanf("%s", items[i].name);
        printf("Enter quantity of %s: ", items[i].name);
        scanf("%d", &items[i].quantity);
        printf("Enter price of %s: ", items[i].name);
        scanf("%f", &items[i].price);

        total += items[i].quantity * items[i].price;
    }

    // Apply discount logic
    if(total > 1000) {
        discount = total * 0.10; // 10% discount
    } else if(total > 500) {
        discount = total * 0.05; // 5% discount
    }

    finalAmount = total - discount;

    printf("\n--- Grocery Bill Receipt ---\n");
    for(i = 0; i < n; i++) {
        printf("%s x %d = %.2f\n", items[i].name, items[i].quantity, items[i].quantity * items[i].price);
    }
    printf("\nTotal: %.2f", total);
    printf("\nDiscount: %.2f", discount);
    printf("\nFinal Amount to Pay: %.2f\n", finalAmount);

    return 0;
}
