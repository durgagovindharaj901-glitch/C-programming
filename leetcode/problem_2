class Solution {
public:
    int lengthOfLongestSubstring(string s) {
        vector<int> index(256, -1); 
        int maxLen = 0;
        int start = 0; 

        for (int i = 0; i < s.size(); i++) {
            char c = s[i];
            if (index[c] >= start) {
                start = index[c] + 1;
            }
            index[c] = i; 
            maxLen = max(maxLen, i - start + 1);
        }

        return maxLen;
    }
};
